{
  "manifest_version": 3,
  "name": "Oksskolten Clip",
  "version": "1.0.0",
  "description": "Clip the active tab URL into Oksskolten",
  "permissions": ["activeTab", "storage", "notifications", "tabs"],
  "host_permissions": [
    "https://oksskolten-atsushi.fly.dev/*",
    "http://localhost:3000/*"
  ],
  "action": {
    "default_title": "Clip active tab"
  },
  "options_page": "options.html",
  "background": {
    "service_worker": "service_worker.js"
  }
}
